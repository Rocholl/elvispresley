# Copiar en el VPS: cp .env.example .env

# Repo a clonar dentro del volumen Docker
# Público (recomendado):
GIT_REPO_URL=https://github.com/Rocholl/elvispresley.git
# Privado (requiere docker-compose.override.yml + deploy-key):
# GIT_REPO_URL=git@github.com:Rocholl/elvispresley.git

# Perfil de Smule a descargar
SMULE_USER=ElvaTorales1

# Opcional: ruta del clone dentro del volumen (default /data/repo)
# REPO_DIR=/data/repo

# Opcional: navegador Playwright (vacío = Chromium en Docker; en macOS: chrome)
# PLAYWRIGHT_CHANNEL=
